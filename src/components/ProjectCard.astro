---
import FormattedDate from './FormattedDate.astro';

const { title, url, description, tags, status, pubDate } = Astro.props;
---
<div class="project-card">
	<div class="project-header">
		<a href={url}><h3>{title}</h3></a>
		{status && <span class={`status ${status}`}>{status}</span>}
	</div>
	<p class="project-description">{description}</p>
	{tags && tags.length > 0 && (
		<div class="project-tags">
			{tags.map((tag: string) => (
				<a href={`/tags/${tag}`} class="tag">{tag}</a>
			))}
		</div>
	)}
	<div class="project-date">
		<FormattedDate date={pubDate} />
	</div>
</div>

<style>
	.project-card {
		border: 1px solid var(--border-color);
		border-radius: 8px;
		padding: 1.5em;
		margin-bottom: 1.5em;
		transition: box-shadow 0.2s;
	}
	.project-card:hover {
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
	}
	:global(.dark) .project-card {
		border-color: var(--border-color-dark);
	}
	:global(.dark) .project-card:hover {
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
	}
	.project-header {
		display: flex;
		align-items: center;
		gap: 0.75em;
		margin-bottom: 0.5em;
	}
	.project-header h3 {
		margin: 0;
	}
	.project-header a {
		color: var(--link-color);
		text-decoration: none;
	}
	.project-header a:hover {
		text-decoration: underline;
	}
	:global(.dark) .project-header a {
		color: var(--link-color-dark);
	}
	.status {
		font-size: 0.75em;
		padding: 0.2em 0.6em;
		border-radius: 1em;
		font-weight: 600;
		text-transform: uppercase;
	}
	.status.active {
		background-color: #e6f4ea;
		color: #1e7e34;
	}
	.status.completed {
		background-color: #e8f0fe;
		color: #1a73e8;
	}
	.status.archived {
		background-color: #f1f3f4;
		color: #5f6368;
	}
	:global(.dark) .status.active {
		background-color: #1e3a2a;
		color: #6fcf8a;
	}
	:global(.dark) .status.completed {
		background-color: #1a2a4a;
		color: var(--link-color-dark);
	}
	:global(.dark) .status.archived {
		background-color: #2a2a2a;
		color: #aaa;
	}
	.project-description {
		color: var(--muted-text);
		margin: 0.5em 0;
	}
	:global(.dark) .project-description {
		color: var(--muted-text-dark);
	}
	.project-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4em;
		margin-top: 0.75em;
	}
	.tag {
		font-size: 0.8em;
		padding: 0.2em 0.6em;
		border: 1px dotted var(--tag-border);
		border-radius: 0.5em;
		background-color: var(--tag-bg);
		color: var(--link-color);
		text-decoration: none;
	}
	.tag:hover {
		background-color: var(--tag-hover-bg);
	}
	:global(.dark) .tag {
		background-color: var(--tag-bg-dark);
		border-color: var(--tag-border-dark);
		color: var(--link-color-dark);
	}
	:global(.dark) .tag:hover {
		background-color: var(--tag-hover-bg-dark);
	}
	.project-date {
		margin-top: 0.75em;
		font-size: 0.85em;
		color: var(--subtle-text);
	}
	:global(.dark) .project-date {
		color: var(--subtle-text-dark);
	}
</style>
